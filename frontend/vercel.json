{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://siderae-blenkir-production.up.railway.app/api/$1" },
    { "source": "/sanctum/csrf-cookie", "destination": "https://siderae-blenkir-production.up.railway.app/sanctum/csrf-cookie" },
    { "source": "/login", "destination": "https://siderae-blenkir-production.up.railway.app/login" },
    { "source": "/logout", "destination": "https://siderae-blenkir-production.up.railway.app/logout" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
