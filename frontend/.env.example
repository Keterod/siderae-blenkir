# ============================================================
# Variables de entorno — Frontend SIDERAE-Blenkir
# ============================================================

# URL base del backend Laravel.
#
# DESARROLLO LOCAL (Docker Compose):
#   Dejar en blanco. El proxy de Vite redirige /api, /login, /logout
#   y /sanctum al backend automáticamente.
#
# PRODUCCIÓN (Vercel):
#   Establecer la URL pública de Railway del backend Laravel.
#   Ejemplo: VITE_API_URL=https://siderae-backend.up.railway.app
#
VITE_API_URL=

# URL base del servicio ML (Flask).
#
# DESARROLLO LOCAL (Docker Compose):
#   Dejar en blanco. El backend Laravel llama directamente al
#   ML Service vía ML_SERVICE_URL (variable de entorno del backend).
#   El frontend no llama directamente al ML Service en este proyecto.
#
# PRODUCCIÓN:
#   Solo si el frontend necesita llamar directamente al ML Service.
#   En la arquitectura actual el frontend NO llama al ML; la variable
#   se documenta aquí para compatibilidad futura.
#   Ejemplo: VITE_ML_URL=https://siderae-ml.up.railway.app
#
VITE_ML_URL=
