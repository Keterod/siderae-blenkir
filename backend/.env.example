# ============================================================
# Variables de entorno — Backend Laravel SIDERAE-Blenkir
# ============================================================
# Copia este archivo como .env y ajusta los valores según entorno.
# NUNCA subas .env real al repositorio.
# ============================================================

# ------------------------------------------------------------
# APLICACIÓN
# ------------------------------------------------------------
APP_NAME=SIDERAE
APP_ENV=local

# Clave de cifrado — generar con: php artisan key:generate
APP_KEY=

# DESARROLLO LOCAL:  APP_DEBUG=true
# PRODUCCIÓN (Railway): APP_DEBUG=false
APP_DEBUG=true

# DESARROLLO LOCAL:  APP_URL=http://localhost:8000
# PRODUCCIÓN (Railway): Railway asigna una URL automática.
#   Ejemplo: APP_URL=https://siderae-backend.up.railway.app
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------
# DESARROLLO LOCAL (Docker Compose):
DB_CONNECTION=mysql
DB_HOST=db-mysql
DB_PORT=3306
DB_DATABASE=siderae_db
DB_USERNAME=root
DB_PASSWORD=secret

# PRODUCCIÓN (Railway MySQL):
# Railway inyecta estas variables automáticamente cuando vinculas el
# plugin MySQL. Copia los valores desde el panel de Railway:
#   DB_HOST=<MYSQLHOST>
#   DB_PORT=<MYSQLPORT>
#   DB_DATABASE=<MYSQLDATABASE>
#   DB_USERNAME=<MYSQLUSER>
#   DB_PASSWORD=<MYSQLPASSWORD>

# ------------------------------------------------------------
# SESIÓN
# ------------------------------------------------------------
# SESSION_DRIVER se mantiene como estaba (database).
# En Railway, la tabla sessions se crea con php artisan migrate.
SESSION_DRIVER=database
SESSION_LIFETIME=120

# DESARROLLO LOCAL: dejar SESSION_DOMAIN en blanco
# PRODUCCIÓN (Railway + Vercel cross-origin):
#   SESSION_DOMAIN debe ser el dominio Railway SIN protocolo.
#   Ejemplo: SESSION_DOMAIN=siderae-backend.up.railway.app
SESSION_DOMAIN=

# DESARROLLO LOCAL: SESSION_SECURE_COOKIE=false
# PRODUCCIÓN: SESSION_SECURE_COOKIE=true (Railway usa HTTPS)
SESSION_SECURE_COOKIE=false

# DESARROLLO LOCAL: SESSION_SAME_SITE=lax
# PRODUCCIÓN cross-origin (Vercel → Railway): SESSION_SAME_SITE=none
# (Requiere SESSION_SECURE_COOKIE=true)
SESSION_SAME_SITE=lax

# ------------------------------------------------------------
# SANCTUM — Dominios con autenticación stateful (SPA)
# ------------------------------------------------------------
# DESARROLLO LOCAL:
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# PRODUCCIÓN (Railway + Vercel):
# Añadir el dominio Vercel del frontend SIN protocolo.
# Ejemplo: SANCTUM_STATEFUL_DOMAINS=siderae-app.vercel.app
# Si tienes dominio custom: SANCTUM_STATEFUL_DOMAINS=tu-dominio.com

# ------------------------------------------------------------
# CORS / FRONTEND
# ------------------------------------------------------------
# DESARROLLO LOCAL:
FRONTEND_URL=http://localhost:5173

# PRODUCCIÓN (Railway + Vercel):
# Establecer la URL completa del frontend en Vercel.
# Ejemplo: FRONTEND_URL=https://siderae-app.vercel.app

# ------------------------------------------------------------
# MICROSERVICIO ML
# ------------------------------------------------------------
# DESARROLLO LOCAL (Docker Compose):
ML_SERVICE_URL=http://ml-engine:5000

# PRODUCCIÓN (Railway):
# Ejemplo: ML_SERVICE_URL=https://siderae-ml.up.railway.app

# ------------------------------------------------------------
# CACHÉ
# ------------------------------------------------------------
# CACHE_DRIVER se mantiene sin cambios.
CACHE_STORE=database
CACHE_PREFIX=siderae_cache

# ------------------------------------------------------------
# QUEUE
# ------------------------------------------------------------
# QUEUE_CONNECTION se mantiene sin cambios.
QUEUE_CONNECTION=database

# ------------------------------------------------------------
# LOGS
# ------------------------------------------------------------
# DESARROLLO LOCAL:
LOG_CHANNEL=stack
LOG_LEVEL=debug

# PRODUCCIÓN (Railway):
# Cambiar a stderr para que Railway capture los logs en su panel.
# LOG_CHANNEL=stderr
# LOG_LEVEL=error

# ------------------------------------------------------------
# PROXY (Railway)
# ------------------------------------------------------------
# Railway termina TLS en su balanceador y reenvía por HTTP interno.
# TRUSTED_PROXIES=* hace que Laravel confíe en los headers X-Forwarded-*.
# Necesario para que APP_URL y las cookies HTTPS funcionen correctamente.
TRUSTED_PROXIES=*
