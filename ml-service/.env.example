# ============================================================
# Variables de entorno — ML Service SIDERAE-Blenkir (Flask)
# ============================================================

# DESARROLLO LOCAL (Docker Compose):
ML_HOST=0.0.0.0
ML_PORT=5000

# PRODUCCIÓN (Railway):
# Railway inyecta PORT automáticamente. No establecer manualmente.
# El servicio lee PORT primero, luego ML_PORT, luego usa 5000 por defecto.
# PORT=    <- Railway lo gestiona automáticamente

# Entorno Flask
# DESARROLLO LOCAL:
FLASK_ENV=development
# PRODUCCIÓN (Railway):
# FLASK_ENV=production
